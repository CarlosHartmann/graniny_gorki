      "source": [
        "#| label: fig-context-accuracy\n",
        "#| fig-cap: Accuracy for context-dependent and context-independent items for two different LLM strategies and the culled human mean\n",
        "\n",
        "# Prepare data for plotting\n",
        "plot_df = pd.DataFrame([\n",
        "    {\n",
