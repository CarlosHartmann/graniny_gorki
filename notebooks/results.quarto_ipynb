        "# Compute time per 100 examples\n",
        "df[\"time_per_100_examples\"] = df[\"total_time_h\"] / df[\"total_annotated_examples\"] * 100\n",
        "\n",
        "# Set colors (reuse previous color_map)\n",
        "colors = [color_map.get(g, \"#888888\") for g in df[\"group\"]]\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(6, 4))\n",
        "bars = ax.bar(df[\"group\"], df[\"time_per_100_examples\"], color=colors, edgecolor=\"black\", linewidth=1.5)\n",
        "ax.set_ylabel(\"Time per 100 Examples (hours)\", fontsize=12)\n",
        "ax.set_xlabel(\"\")\n",
        "ax.grid(axis=\"y\", alpha=0.3)\n",
        "ax.set_axisbelow(True)\n",
