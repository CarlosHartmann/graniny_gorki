        "ax.set_ylabel(\"Cost per 100 Examples ($)\", fontsize=12)\n",
        "ax.set_xlabel(\"\")\n",
        "ax.grid(axis=\"y\", alpha=0.3)\n",
        "ax.set_axisbelow(True)\n",
        "plt.tight_layout()\n",
        "plt.show()"
