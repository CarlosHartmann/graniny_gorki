      "cell_type": "code",
      "metadata": {},
      "source": [
        "\"Functions for obtaining accuracy performances\"\n",
        "\n",
        "def compute_accuracy(participant_dict, context_dependent=0):\n",
        "    \"\"\"\n",
        "    context_dependent:\n",
        "      0 -> use all eligible items\n",
        "      1 -> use ONLY IDs in context_dependent_ids\n",
        "      2 -> SKIP IDs in context_dependent_ids\n",
        "    \"\"\"\n",
        "    if context_dependent not in (0, 1, 2):\n",
        "        raise ValueError(\"context_dependent must be 0, 1, or 2.\")\n",
        "\n",
        "    # sanity check for required GT columns\n",
        "    if \"ID\" not in gt.columns or \"they_type\" not in gt.columns:\n",
        "        raise ValueError(\"Ground Truth must contain 'ID' and 'they_type' columns.\")\n",
        "\n",
        "    # fast lookup: ID -> normalized they_type\n",
        "    gt_lookup = (\n",
        "        gt[[\"ID\", \"they_type\"]]\n",
        "        .dropna(subset=[\"ID\"])\n",
        "        .assign(ID=lambda d: d[\"ID\"].astype(str).str.strip())\n",
        "        .set_index(\"ID\")[\"they_type\"]\n",
        "        .to_dict()\n",
        "    )\n",
        "    gt_lookup = {k: _norm_type(v) for k, v in gt_lookup.items()}\n",
        "\n",
        "    correct = 0\n",
        "    total = 0\n",
        "\n",
        "    for key, pred_val in participant_dict.items():\n",
        "        # only evaluate non-comment items that are LoRes or ma_era\n",
        "        if \"[comment]\" in key:\n",
        "            continue\n",
        "        if (\"LoRes\" not in key) and (\"ma_era\" not in key):\n",
        "            continue\n",
        "\n",
        "        kid = key.strip()\n",
        "\n",
        "        # apply context-dependency filter\n",
        "        if context_dependent == 1 and kid not in context_dependent_ids:\n",
        "            continue\n",
        "        if context_dependent == 2 and kid in context_dependent_ids:\n",
        "            continue\n",
        "\n",
        "        # require GT present\n",
        "        if kid not in gt_lookup:\n",
        "            print(\"Did not find example in Ground Truth\")\n",
        "            continue\n",
        "\n",
        "        total += 1\n",
        "        gt_val = gt_lookup[kid].replace(\"_they\", \"\")\n",
        "        pred_norm = _norm_type(pred_val)\n",
        "\n",
        "        if pred_norm == gt_val:\n",
        "            correct += 1\n",
        "\n",
        "    return (correct / total) if total else float(\"nan\")\n",
        "\n",
        "def compute_accuracy_by_label(participant_dict, context_dependent=0,\n",
        "                              labels=(\"generic_they\", \"singular_they\", \"plural_they\")):\n",
        "    \"\"\"\n",
        "    Returns a dict mapping each label to its accuracy, computed over items whose GT is that label.\n",
        "    context_dependent:\n",
        "      0 -> use all eligible items\n",
        "      1 -> ONLY IDs in context_dependent_ids\n",
        "      2 -> SKIP IDs in context_dependent_ids\n",
        "    \"\"\"\n",
        "    if context_dependent not in (0, 1, 2):\n",
        "        raise ValueError(\"context_dependent must be 0, 1, or 2.\")\n",
        "\n",
        "    # sanity check\n",
        "    if \"ID\" not in gt.columns or \"they_type\" not in gt.columns:\n",
        "        raise ValueError(\"Ground Truth must contain 'ID' and 'they_type' columns.\")\n",
        "\n",
        "    # GT lookup with normalized labels\n",
        "    gt_lookup = (\n",
        "        gt[[\"ID\", \"they_type\"]]\n",
        "        .dropna(subset=[\"ID\"])\n",
        "        .assign(ID=lambda d: d[\"ID\"].astype(str).str.strip())\n",
        "        .set_index(\"ID\")[\"they_type\"]\n",
        "        .to_dict()\n",
        "    )\n",
        "    gt_lookup = {k: _norm_type(v) for k, v in gt_lookup.items()}\n",
        "\n",
        "    totals = {lbl: 0 for lbl in labels}\n",
        "    corrects = {lbl: 0 for lbl in labels}\n",
        "\n",
        "    for key, pred_val in participant_dict.items():\n",
        "        # only evaluate non-comment items that are LoRes or ma_era\n",
        "        if \"[comment]\" in key:\n",
        "            continue\n",
        "        if (\"LoRes\" not in key) and (\"ma_era\" not in key):\n",
        "            continue\n",
        "\n",
        "        kid = key.strip()\n",
        "\n",
        "        # apply context-dependency filter\n",
        "        if context_dependent == 1 and kid not in context_dependent_ids:\n",
        "            continue\n",
        "        if context_dependent == 2 and kid in context_dependent_ids:\n",
        "            continue\n",
        "\n",
        "        if kid not in gt_lookup:\n",
        "            continue\n",
        "\n",
        "        gt_val = gt_lookup[kid]\n",
        "        if gt_val not in totals:  # ignore unexpected GT labels\n",
        "            continue\n",
        "\n",
        "        pred_norm = _norm_type(pred_val)\n",
        "        totals[gt_val] += 1\n",
        "        if pred_norm == gt_val:\n",
        "            corrects[gt_val] += 1\n",
        "\n",
        "    # compute accuracies per label\n",
        "    accs = {}\n",
        "    for lbl in labels:\n",
        "        if totals[lbl] == 0:\n",
        "            accs[lbl] = float(\"nan\")\n",
        "        else:\n",
        "            accs[lbl] = corrects[lbl] / totals[lbl]\n",
        "    return accs\n",
        "\n",
        "def _norm_type(x):\n",
        "    # normalize labels to a canonical set for comparison\n",
        "    if x is None:\n",
        "        return \"\"\n",
        "    s = str(x).strip().lower()\n",
        "    if s in {\"\", \"nan\", \"none\"}:\n",
        "        return \"\"\n",
        "    mapping = {\n",
        "        # singular\n",
        "        \"sing\": \"singular\", \"sing.\": \"singular\", \"s\": \"singular\", \"sg\": \"singular\",\n",
        "        \"singular\": \"singular\", \"singular_they\":\"singular\",\n",
        "        # plural\n",
        "        \"pl\": \"plural\", \"pl.\": \"plural\", \"p\": \"plural\", \"plural\": \"plural\", \"plural_they\":\"plural\",\n",
        "        # generic\n",
        "        \"gen\": \"generic\", \"gen.\": \"generic\", \"g\": \"generic\", \"generic\": \"generic\", \"generic_they\":\"generic\"\n",
        "    }\n",
        "    return mapping.get(s, s)  # fallback to the cleaned string if unseen"
      ],
      "id": "2fb7edb3",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "\"Calculating accuracies and storing them as dicts\"\n",
        "\n",
        "accuracy_dict_commercial_llms = {}\n",
        "for llm in commercial_llm_responses:\n",
        "    accuracies = list()\n",
        "    for run in commercial_llm_responses[llm]:\n",
        "        acc = compute_accuracy(run)\n",
        "        accuracies.append(acc)\n",
        "    accuracy_dict_commercial_llms[llm] = accuracies\n",
        "\n",
        "accuracy_dict_opensource_llms = {}\n",
        "for llm in opensource_llm_responses:\n",
        "    accuracies = list()\n",
        "    for run in opensource_llm_responses[llm]:\n",
        "        acc = compute_accuracy(run)\n",
        "        accuracies.append(acc)\n",
        "    accuracy_dict_opensource_llms[llm] = accuracies\n",
        "\n",
        "accuracy_dict_local_llms = {}\n",
        "for llm in local_llm_responses:\n",
        "    accuracies = list()\n",
        "    for run in local_llm_responses[llm]:\n",
        "        acc = compute_accuracy(run)\n",
        "        accuracies.append(acc)\n",
        "    accuracy_dict_local_llms[llm] = accuracies\n",
        "\n",
        "\n",
        "human_blocks = [block_a, block_b, block_c, block_d, block_pilot]\n",
        "\n",
        "accuracy_dict_humans = {}\n",
        "for block_name, block in zip([\"A\", \"B\", \"C\", \"D\", \"Pilot\"], human_blocks):\n",
        "    accuracies = []\n",
        "    for participant in block:\n",
        "        acc = compute_accuracy(participant)\n",
        "        accuracies.append(acc)\n",
        "    accuracy_dict_humans[f\"block_{block_name}\"] = accuracies\n",
        "\n",
        "# build an accuracy dict for the non-linguists control group\n",
        "\n",
        "\n",
        "accuracies = []\n",
        "for participant in non_ling_participants:\n",
        "    acc = compute_accuracy(participant)\n",
        "    accuracies.append(acc)\n",
        "accuracy_dict_non_linguists = {\"non-linguists\":accuracies}\n",
        "    \n",
        "\n",
        "# build an accuracy dict for all data found in gt using human-majority\n",
        "\n",
        "def get_human_majority_vote(data_point_id):\n",
        "    \"\"\"Get the majority vote from all human annotators for a given data point.\"\"\"\n",
        "    votes = []\n",
        "    for block in human_blocks:\n",
        "        for participant in block:\n",
        "            if data_point_id in participant:\n",
        "                votes.append(_norm_type(participant[data_point_id]))\n",
        "    \n",
        "    if not votes:\n",
        "        return None\n",
        "    \n",
        "    counter = Counter(votes)\n",
        "    majority_vote, _ = counter.most_common(1)[0]\n",
        "    return majority_vote\n",
        "\n",
        "majority_vote_dict = {}\n",
        "for data_point_id in gt[\"ID\"].dropna().astype(str).str.strip():\n",
        "    majority_vote = get_human_majority_vote(data_point_id)\n",
        "    if majority_vote:\n",
        "        majority_vote_dict[data_point_id] = majority_vote\n",
        "\n",
        "accuracy_dict_humans[\"majority_vote\"] = [compute_accuracy(majority_vote_dict)]"
      ],
      "id": "003ec337",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Hypothesis 1\n",
        "\n",
        "The first hypothesis aims to test if any LLM-based approach would yield the highest overall performance."
      ],
      "id": "9b403263"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: tbl-top10-accuracy\n",
        "#| tbl-cap: The ten highest-performing participants by accuracy\n",
        "\n",
        "# List all accuracies and from where they came from (participant block) in descending order\n",
        "accuracy_results = []\n",
        "\n",
        "# Add human block results\n",
        "for block_name, accuracies in accuracy_dict_humans.items():\n",
        "    for i, acc in enumerate(accuracies):\n",
        "        accuracy_results.append({\n",
        "            \"source\": block_name,\n",
        "            \"accuracy\": acc\n",
        "        })\n",
        "\n",
        "# Add non-linguist humans results\n",
        "for num, acc in enumerate(accuracy_dict_non_linguists[\"non-linguists\"]):\n",
        "    accuracy_results.append({\n",
        "        \"source\": f\"Non-Linguist Human Nr. {num+1}\",\n",
        "        \"accuracy\": acc\n",
        "    })\n",
        "\n",
        "# Add LLM results taking the mean of all runs per LLM\n",
        "all_llms = list(accuracy_dict_commercial_llms.items()) + list(accuracy_dict_opensource_llms.items()) + list(accuracy_dict_local_llms.items())\n",
        "for llm_name, accuracies in all_llms:\n",
        "    mean_acc = sum(accuracies) / len(accuracies) if accuracies else float(\"nan\")\n",
        "    accuracy_results.append({\n",
        "        \"source\": llm_name,\n",
        "        \"accuracy\": mean_acc\n",
        "    })\n",
        "\n",
        "# Sort by accuracy in descending order\n",
        "accuracy_results.sort(key=lambda x: x[\"accuracy\"], reverse=True)\n",
        "\n",
        "# Keep only top 10\n",
        "accuracy_results = accuracy_results[:10]\n",
        "\n",
        "# display accuracy as full percentages without decimal places\n",
        "for result in accuracy_results:\n",
        "    result[\"accuracy\"] = f\"{result['accuracy'] * 100:.0f}%\"\n",
        "\n",
        "# Display results\n",
        "import pandas as pd\n",
        "results_df = pd.DataFrame(accuracy_results)\n",
        "\n",
        "Markdown(results_df.to_markdown(index=False, headers=[\"Participant Group\", \"Accuracy\"]))"
      ],
      "id": "tbl-top10-accuracy",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Hypothesis 2"
      ],
      "id": "bdcd087c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "\"Constants\"\n",
        "CULLING_THRESHHOLD = 1/3\n",
        "CULLING_THRESHHOLD_PERCENT = f\"{CULLING_THRESHHOLD * 100:.0f}%\""
      ],
      "id": "d4ebd3a2",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: tbl-l1-vs-l2-vs-nonling\n",
        "#| tbl-cap: Overall accuracy by three human groups\n",
        "\n",
        "# Comparing the three groups of human annotators\n",
        "\n",
        "# Build accuracy dict for non-pilot human annotators\n",
        "non_pilot_blocks = [block_a, block_b, block_c, block_d]\n",
        "accuracy_dict_non_pilot_humans = {}\n",
        "for block_name, block in zip([\"A\", \"B\", \"C\", \"D\"], non_pilot_blocks):\n",
        "    accuracies = []\n",
        "    for participant in block:\n",
        "        acc = compute_accuracy(participant)\n",
        "        accuracies.append(acc)\n",
        "    accuracy_dict_non_pilot_humans[f\"block_{block_name}\"] = accuracies\n",
        "\n",
        "# Build accuracy dict for pilot human annotators\n",
        "accuracy_dict_pilot_humans = {}\n",
        "accuracies = []\n",
        "for participant in block_pilot:\n",
        "    acc = compute_accuracy(participant)\n",
        "    accuracies.append(acc)\n",
        "accuracy_dict_pilot_humans[\"pilot\"] = accuracies\n",
        "\n",
        "# The accuracy dict for non-linguists is already given as `accuracy_dict_non_linguists`\n",
        "\n",
        "# Calculate three overall accuracies and list in table\n",
        "overall_accuracies = {\n",
        "    \"Non-Pilot Humans\": sum(\n",
        "        acc for accuracies in accuracy_dict_non_pilot_humans.values() for acc in accuracies\n",
        "    ) / sum(len(accuracies) for accuracies in accuracy_dict_non_pilot_humans.values()),\n",
        "    \"Pilot Humans\": sum(\n",
        "        acc for acc in accuracy_dict_pilot_humans[\"pilot\"]\n",
        "    ) / len(accuracy_dict_pilot_humans[\"pilot\"]),\n",
        "    \"Non-Linguists\": sum(\n",
        "        acc for acc in accuracy_dict_non_linguists[\"non-linguists\"]\n",
        "    ) / len(accuracy_dict_non_linguists[\"non-linguists\"]),\n",
        "}\n",
        "\n",
        "# Display results as a table\n",
        "import pandas as pd\n",
        "accuracy_table = pd.DataFrame(\n",
        "    [{\"Group\": group, \"Accuracy\": f\"{accuracy * 100:.1f}%\"} for group, accuracy in overall_accuracies.items()]\n",
        ")\n",
        "Markdown(accuracy_table.to_markdown(index=False))"
      ],
      "id": "tbl-l1-vs-l2-vs-nonling",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Run statistical analysis to ascertain whether their differences are statistically significant\n",
        "from scipy.stats import f_oneway\n",
        "\n",
        "# Prepare data for ANOVA\n",
        "anova_data = [\n",
        "    (group, acc)\n",
        "    for group, accuracies in [\n",
        "        (\"Non-Pilot Humans\", [acc for accuracies in accuracy_dict_non_pilot_humans.values() for acc in accuracies]),\n",
        "        (\"Pilot Humans\", accuracy_dict_pilot_humans[\"pilot\"]),\n",
        "        (\"Non-Linguists\", accuracy_dict_non_linguists[\"non-linguists\"]),\n",
        "    ]\n",
        "    for acc in accuracies\n",
        "]\n",
        "\n",
        "# Group data by annotator type\n",
        "anova_groups = {\n",
        "    group: [acc for g, acc in anova_data if g == group]\n",
        "    for group in [\"Non-Pilot Humans\", \"Pilot Humans\"]\n",
        "}\n",
        "\n",
        "# Perform ANOVA\n",
        "anova_result = f_oneway(*anova_groups.values())\n",
        "anova_p_value = anova_result.pvalue\n",
        "ALPHA_PILOTS_VS_CROWD = 0.05"
      ],
      "id": "fe2c1f52",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "The difference between the crowdworkers and the local student pilot participants is `{python} \"not\" if anova_p_value >= ALPHA_PILOTS_VS_CROWD else \"\"` statistically significant (`{python} f\"p = {round(anova_p_value, 3)}, α = {ALPHA_PILOTS_VS_CROWD}\"`).\n"
      ],
      "id": "d0fcb100"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "\"Culling of human annotators\"\n",
        "\n",
        "# Compute context-dependent accuracy for each human participant\n",
        "context_dependent_accuracies = {}\n",
        "for block_name, block in zip([\"A\", \"B\", \"C\", \"D\", \"Pilot\"], human_blocks):\n",
        "    for i, participant in enumerate(block):\n",
        "        participant_id = f\"{block_name}_{i}\"\n",
        "        acc = compute_accuracy(participant, context_dependent=1)\n",
        "        context_dependent_accuracies[participant_id] = acc\n",
        "\n",
        "# Filter out participants with context-dependent accuracy at or below chance (33%)\n",
        "filtered_participants = {pid: acc for pid, acc in context_dependent_accuracies.items() \n",
        "                         if acc > CULLING_THRESHHOLD}\n",
        "\n",
        "# Sort by accuracy and take top half\n",
        "sorted_participants = sorted(filtered_participants.items(), key=lambda x: x[1], reverse=True)\n",
        "top_half_count = len(sorted_participants) // 2\n",
        "culled_participants = sorted_participants[:top_half_count]\n",
        "\n",
        "# Reconstruct accuracy dict for culled participants only\n",
        "accuracy_dict_humans_culled = {}\n",
        "culled_participant_ids = {pid for pid, _ in culled_participants}\n",
        "\n",
        "for block_name, block in zip([\"A\", \"B\", \"C\", \"D\", \"Pilot\"], human_blocks):\n",
        "    culled_block_accuracies = []\n",
        "    for i, participant in enumerate(block):\n",
        "        participant_id = f\"{block_name}_{i}\"\n",
        "        if participant_id in culled_participant_ids:\n",
        "            acc = compute_accuracy(participant)\n",
        "            culled_block_accuracies.append(acc)\n",
        "    if culled_block_accuracies:\n",
        "        accuracy_dict_humans_culled[f\"block_{block_name}_culled\"] = culled_block_accuracies\n",
        "\n",
        "# report the mean accuracy of the culled accuracies\n",
        "mean_culled_accuracy = sum(\n",
        "    acc for accuracies in accuracy_dict_humans_culled.values() \n",
        "    for acc in accuracies\n",
        ") / sum(len(accuracies) for accuracies in accuracy_dict_humans_culled.values())\n",
        "\n",
        "participant_num_culled = len(culled_participant_ids)\n",
        "participant_num_pilot = sum(1 for pid in culled_participant_ids if pid.startswith(\"Pilot_\"))\n",
        "participant_num_block_abcd = participant_num_culled - participant_num_pilot"
      ],
      "id": "324b1a6b",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "The group of culled participants has `{python} participant_num_culled` participants, of which `{python} participant_num_pilot if participant_num_pilot > 12 else num2words(participant_num_pilot)` are local students and `{python} participant_num_block_abcd` are crowdworkers."
      ],
      "id": "72f1a8dc"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "\"Preparing relevant data for Figure\"\n",
        "\n",
        "hypothesis_2_results = dict()\n",
        "\n",
        "# Overall human mean\n",
        "overall_human_mean = sum(\n",
        "    acc for accuracies in accuracy_dict_humans.values() \n",
        "    for acc in accuracies\n",
        ") / sum(len(accuracies) for accuracies in accuracy_dict_humans.values())\n",
        "\n",
        "# Culled human mean (already computed above)\n",
        "# mean_culled_accuracy is already available\n",
        "\n",
        "nonlinguist_humans = sum(accuracy_dict_non_linguists[\"non-linguists\"]) / len(accuracy_dict_non_linguists[\"non-linguists\"])\n",
        "\n",
        "# Build a majority-vote dict using only culled humans\n",
        "culled_human_blocks = []\n",
        "for block_name, block in zip([\"A\", \"B\", \"C\", \"D\", \"Pilot\"], human_blocks):\n",
        "    culled_block = []\n",
        "    for i, participant in enumerate(block):\n",
        "        participant_id = f\"{block_name}_{i}\"\n",
        "        if participant_id in culled_participant_ids:\n",
        "            culled_block.append(participant)\n",
        "    if culled_block:\n",
        "        culled_human_blocks.append(culled_block)\n",
        "\n",
        "def get_culled_majority_vote(data_point_id):\n",
        "    votes = []\n",
        "    for block in culled_human_blocks:\n",
        "        for participant in block:\n",
        "            if data_point_id in participant:\n",
        "                votes.append(_norm_type(participant[data_point_id]))\n",
        "    if not votes:\n",
        "        return None\n",
        "    counter = Counter(votes)\n",
        "    majority_vote, _ = counter.most_common(1)[0]\n",
        "    return majority_vote\n",
        "\n",
        "culled_majority_vote_dict = {}\n",
        "for data_point_id in gt[\"ID\"].dropna().astype(str).str.strip():\n",
        "    majority_vote = get_culled_majority_vote(data_point_id)\n",
        "    if majority_vote:\n",
        "        culled_majority_vote_dict[data_point_id] = majority_vote\n",
        "\n",
        "culled_majority_vote_accuracy = compute_accuracy(culled_majority_vote_dict)\n",
        "hypothesis_2_results[\"culled_majority_vote_accuracy\"] = culled_majority_vote_accuracy\n",
        "\n",
        "# Compute mean accuracy for each LLM across all runs\n",
        "commercial_llm_means = {\n",
        "    llm_name: sum(accuracies) / len(accuracies) \n",
        "    for llm_name, accuracies in accuracy_dict_commercial_llms.items()\n",
        "}\n",
        "\n",
        "opensource_llm_means = {\n",
        "    llm_name: sum(accuracies) / len(accuracies) \n",
        "    for llm_name, accuracies in accuracy_dict_opensource_llms.items()\n",
        "}\n",
        "\n",
        "local_llm_means = {\n",
        "    llm_name: sum(accuracies) / len(accuracies) \n",
        "    for llm_name, accuracies in accuracy_dict_local_llms.items()\n",
        "}\n",
        "\n",
        "# Get top 3 commercial LLMs by mean accuracy\n",
        "top_3_commercial_llms = sorted(commercial_llm_means.items(), key=lambda x: x[1], reverse=True)[:3]\n",
        "\n",
        "# Get top 3 opensource LLMs by mean accuracy\n",
        "top_3_opensource_llms = sorted(opensource_llm_means.items(), key=lambda x: x[1], reverse=True)[:3]\n",
        "\n",
        "# Get top 3 local LLMs by mean accuracy\n",
        "top_3_local_llms = sorted(local_llm_means.items(), key=lambda x: x[1], reverse=True)[:3]\n",
        "\n",
        "# Combine top 3 LLMs from both groups\n",
        "top_3_llms = sorted(\n",
        "    top_3_commercial_llms + top_3_opensource_llms + top_3_local_llms,\n",
        "    key=lambda x: x[1],\n",
        "    reverse=True\n",
        ")[:3]\n",
        "\n",
        "\n",
        "# Create results dict\n",
        "hypothesis_2_results = {\n",
        "    \"non-linguist_human_mean\": nonlinguist_humans,\n",
        "    \"overall_human_mean\": overall_human_mean,\n",
        "    \"culled_human_mean\": mean_culled_accuracy,\n",
        "    \"culled_human_majority_vote_accuracy\": culled_majority_vote_accuracy\n",
        "}\n",
        "\n",
        "# Flatten top 3 commercial LLM means into the results dict\n",
        "for llm_name, acc in top_3_llms:\n",
        "    hypothesis_2_results[f\"top_3_llm_mean_{llm_name}\"] = acc"
      ],
      "id": "f29c787a",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-overall-acc-comparison\n",
        "#| fig-cap: Participant accuracies with 95% confidence interval\n",
        "#| fig-subcap:\n",
        "#|   - Human Group Accuracies\n",
        "#|   - Commercial LLM Accuracies\n",
        "#|   - Open Source LLM Accuracies\n",
        "#|   - Local LLM Accuracies\n",
        "#| layout-nrow: 2\n",
        "#| layout-ncol: 2\n",
        "\n",
        "\n",
        "top_3_commercial_llms_namemapped = [\n",
        "    {\"label\": label_mapping.get(llm_name, llm_name), \"value\": acc}\n",
        "    for llm_name, acc in top_3_commercial_llms\n",
        "]\n",
        "\n",
        "top_3_opensource_llms_namemapped = [\n",
        "    {\"label\": label_mapping.get(llm_name, llm_name), \"value\": acc}\n",
        "    for llm_name, acc in top_3_opensource_llms\n",
        "]\n",
        "\n",
        "top_3_local_llms_namemapped = [\n",
        "    {\"label\": label_mapping.get(llm_name, llm_name), \"value\": acc}\n",
        "    for llm_name, acc in top_3_local_llms\n",
        "]\n",
        "\n",
        "# Palettes\n",
        "human_palette = [\"#D0E1F2\", \"#A3C4E5\", \"#6A9FD1\", \"#2C4C7E\"]\n",
        "llm_palette   = [\"#FFB3B3\", \"#FF7F7F\", \"#B22222\", \"#FFCC99\", \"#FF9966\", \"#CC6600\"]  # Commercial LLMs\n",
        "oss_palette   = [\"#FFCC99\", \"#FFB366\", \"#FF9933\", \"#FF8000\", \"#CC6600\"]  # Open Source LLMs with different tones of orange\n",
        "local_palette = [\"#C9B1D9\", \"#A890C0\", \"#876FA7\", \"#664E8E\"]  # Local LLMs with purple tones\n",
        "\n",
        "# Helper: bootstrap percentile CI for the mean\n",
        "def bootstrap_ci_of_mean(samples, alpha=0.05, B=10000, rng=None):\n",
        "    \"\"\"\n",
        "    Returns (lower, upper) bootstrap CI for the mean of `samples`.\n",
        "    Uses percentile bootstrap; seeded RNG for reproducibility.\n",
        "    \"\"\"\n",
        "    samples = np.asarray(samples, dtype=float)\n",
        "    if rng is None:\n",
        "        rng = np.random.default_rng(42)\n",
        "    n = len(samples)\n",
        "    if n == 0:\n",
        "        return (np.nan, np.nan)\n",
        "    if n == 1:\n",
        "        return (float(samples[0]), float(samples[0]))\n",
        "    boot_idx = rng.integers(0, n, size=(B, n))\n",
        "    boot_means = samples[boot_idx].mean(axis=1)\n",
        "    lower, upper = np.quantile(boot_means, [alpha/2, 1 - alpha/2])\n",
        "    return float(lower), float(upper)\n",
        "\n",
        "# Helper: wrap long labels with line breaks\n",
        "def wrap_label(label, width=15):\n",
        "    \"\"\"Wrap label text to specified width.\"\"\"\n",
        "    return \"\\n\".join(textwrap.wrap(label, width=width))\n",
        "\n",
        "# ---------- Graph 1: All human data ----------\n",
        "non_ling_accs = [compute_accuracy(p, context_dependent=0) for p in non_ling_participants]\n",
        "ling_accs = [compute_accuracy(p, context_dependent=0) for block in human_blocks for p in block]\n",
        "culled_accs = [compute_accuracy(p, context_dependent=0) for block in culled_human_blocks for p in block]\n",
        "culled_majority = float(hypothesis_2_results[\"culled_human_majority_vote_accuracy\"])\n",
        "\n",
        "human_labels = [\n",
        "    \"Non-linguist\\nHuman Mean\",\n",
        "    \"Linguist\\nHuman Mean\",\n",
        "    \"Culled\\nHuman Mean\",\n",
        "    \"Culled\\nHuman Majority\"\n",
        "]\n",
        "human_values = [\n",
        "    float(np.mean(non_ling_accs)),\n",
        "    float(np.mean(ling_accs)),\n",
        "    float(np.mean(culled_accs)),\n",
        "    culled_majority\n",
        "]\n",
        "human_ci = [\n",
        "    bootstrap_ci_of_mean(non_ling_accs),\n",
        "    bootstrap_ci_of_mean(ling_accs),\n",
        "    bootstrap_ci_of_mean(culled_accs),\n",
        "    (culled_majority, culled_majority)\n",
        "]\n",
        "human_err = np.array([(v - lo, hi - v) for v, (lo, hi) in zip(human_values, human_ci)]).T\n",
        "\n",
        "fig1, ax1 = plt.subplots(figsize=(10, 5))\n",
        "ax1.bar(\n",
        "    human_labels,\n",
        "    human_values,\n",
        "    yerr=human_err,\n",
        "    color=human_palette[:len(human_labels)],\n",
        "    edgecolor=\"black\",\n",
        "    linewidth=1.2,\n",
        "    error_kw={\"capsize\": 5, \"elinewidth\": 1.2, \"ecolor\": \"black\"}\n",
        ")\n",
        "ax1.set_ylim(0.33, 1.0)\n",
        "ax1.yaxis.set_major_formatter(plt.FuncFormatter(lambda y, _: f\"{y*100:.0f}%\"))\n",
        "ax1.set_ylabel(\"Accuracy\", fontsize=12)\n",
        "ax1.grid(axis=\"y\", alpha=0.3)\n",
        "ax1.set_axisbelow(True)\n",
        "ax1.tick_params(axis=\"x\", labelsize=15)  # Increased label size\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# ---------- Graph 2: Commercial LLMs ----------\n",
        "commercial_records = []\n",
        "for llm_name, _ in top_3_commercial_llms:\n",
        "    display_name = label_mapping.get(llm_name, llm_name)\n",
        "    run_accs = [compute_accuracy(run, context_dependent=0) for run in commercial_llm_responses.get(llm_name, [])]\n",
        "    if len(run_accs) == 0:\n",
        "        continue\n",
        "    commercial_records.append({\n",
        "        \"label\": display_name,\n",
        "        \"value\": float(np.mean(run_accs)),\n",
        "        \"ci\": bootstrap_ci_of_mean(run_accs)\n",
        "    })\n",
        "\n",
        "commercial_records.sort(key=lambda r: r[\"value\"])\n",
        "com_labels = [wrap_label(r[\"label\"], width=12) for r in commercial_records]\n",
        "com_values = [r[\"value\"] for r in commercial_records]\n",
        "com_ci = [r[\"ci\"] for r in commercial_records]\n",
        "com_err = np.array([(v - lo, hi - v) for v, (lo, hi) in zip(com_values, com_ci)]).T\n",
        "\n",
        "fig2, ax2 = plt.subplots(figsize=(10, 5))\n",
        "ax2.bar(\n",
        "    com_labels,\n",
        "    com_values,\n",
        "    yerr=com_err,\n",
        "    color=llm_palette[:len(com_labels)],\n",
        "    edgecolor=\"black\",\n",
        "    linewidth=1.2,\n",
        "    error_kw={\"capsize\": 5, \"elinewidth\": 1.2, \"ecolor\": \"black\"}\n",
        ")\n",
        "ax2.set_ylim(0.33, 1.0)\n",
        "ax2.yaxis.set_major_formatter(plt.FuncFormatter(lambda y, _: f\"{y*100:.0f}%\"))\n",
        "ax2.set_ylabel(\"Accuracy\", fontsize=12)\n",
        "ax2.grid(axis=\"y\", alpha=0.3)\n",
        "ax2.set_axisbelow(True)\n",
        "ax2.tick_params(axis=\"x\", labelsize=15)  # Increased label size\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# ---------- Graph 3: Open source LLMs ----------\n",
        "opensource_records = []\n",
        "for llm_name, _ in top_3_opensource_llms:\n",
        "    display_name = label_mapping.get(llm_name, llm_name)\n",
        "    run_accs = [compute_accuracy(run, context_dependent=0) for run in opensource_llm_responses.get(llm_name, [])]\n",
        "    if len(run_accs) == 0:\n",
        "        continue\n",
        "    opensource_records.append({\n",
        "        \"label\": display_name,\n",
        "        \"value\": float(np.mean(run_accs)),\n",
        "        \"ci\": bootstrap_ci_of_mean(run_accs)\n",
        "    })\n",
        "\n",
        "opensource_records.sort(key=lambda r: r[\"value\"])\n",
        "oss_labels = [wrap_label(r[\"label\"], width=12) for r in opensource_records]\n",
        "oss_values = [r[\"value\"] for r in opensource_records]\n",
        "oss_ci = [r[\"ci\"] for r in opensource_records]\n",
        "oss_err = np.array([(v - lo, hi - v) for v, (lo, hi) in zip(oss_values, oss_ci)]).T\n",
        "\n",
        "fig3, ax3 = plt.subplots(figsize=(10, 5))\n",
        "ax3.bar(\n",
        "    oss_labels,\n",
        "    oss_values,\n",
        "    yerr=oss_err,\n",
        "    color=oss_palette[:len(oss_labels)],\n",
        "    edgecolor=\"black\",\n",
        "    linewidth=1.2,\n",
        "    error_kw={\"capsize\": 5, \"elinewidth\": 1.2, \"ecolor\": \"black\"}\n",
        ")\n",
        "ax3.set_ylim(0.33, 1.0)\n",
        "ax3.yaxis.set_major_formatter(plt.FuncFormatter(lambda y, _: f\"{y*100:.0f}%\"))\n",
        "ax3.set_ylabel(\"Accuracy\", fontsize=12)\n",
        "ax3.grid(axis=\"y\", alpha=0.3)\n",
        "ax3.set_axisbelow(True)\n",
        "ax3.tick_params(axis=\"x\", labelsize=15)  # Increased label size\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# ---------- Graph 4: Local LLMs ----------\n",
        "local_records = []\n",
        "for llm_name, _ in top_3_local_llms:\n",
        "    display_name = label_mapping.get(llm_name, llm_name)\n",
        "    run_accs = [compute_accuracy(run, context_dependent=0) for run in local_llm_responses.get(llm_name, [])]\n",
        "    if len(run_accs) == 0:\n",
        "        continue\n",
        "    local_records.append({\n",
        "        \"label\": display_name,\n",
        "        \"value\": float(np.mean(run_accs)),\n",
        "        \"ci\": bootstrap_ci_of_mean(run_accs)\n",
        "    })\n",
        "\n",
        "local_records.sort(key=lambda r: r[\"value\"])\n",
        "local_labels = [wrap_label(r[\"label\"], width=12) for r in local_records]\n",
        "local_values = [r[\"value\"] for r in local_records]\n",
        "local_ci = [r[\"ci\"] for r in local_records]\n",
        "local_err = np.array([(v - lo, hi - v) for v, (lo, hi) in zip(local_values, local_ci)]).T\n",
        "\n",
        "fig4, ax4 = plt.subplots(figsize=(10, 5))\n",
        "ax4.bar(\n",
        "    local_labels,\n",
        "    local_values,\n",
        "    yerr=local_err,\n",
        "    color=local_palette[:len(local_labels)],\n",
        "    edgecolor=\"black\",\n",
        "    linewidth=1.2,\n",
        "    error_kw={\"capsize\": 5, \"elinewidth\": 1.2, \"ecolor\": \"black\"}\n",
        ")\n",
        "ax4.set_ylim(0.33, 1.0)\n",
        "ax4.yaxis.set_major_formatter(plt.FuncFormatter(lambda y, _: f\"{y*100:.0f}%\"))\n",
        "ax4.set_ylabel(\"Accuracy\", fontsize=12)\n",
        "ax4.grid(axis=\"y\", alpha=0.3)\n",
        "ax4.set_axisbelow(True)\n",
        "ax4.tick_params(axis=\"x\", labelsize=15)  # Increased label size\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "fig-overall-acc-comparison",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "\"Significance test\"\n",
        "\n",
        "ALPHA = 0.05\n",
        "\n",
        "# McNemar's test to compare best LLM vs. culled humans\n",
        "\n",
        "from statsmodels.stats.contingency_tables import mcnemar\n",
        "\n",
        "# For McNemar's test, we need paired binary outcomes for the same items.\n",
        "# We'll use the majority vote of culled humans vs. the best LLM (majority vote across runs).\n",
        "\n",
        "# Build majority vote for best LLM\n",
        "def get_llm_majority_vote(data_point_id):\n",
        "    votes = []\n",
        "    for run in commercial_llm_responses[top_3_llms[0][0]]:\n",
        "        if data_point_id in run:\n",
        "            votes.append(_norm_type(run[data_point_id]))\n",
        "    if not votes:\n",
        "        return None\n",
        "    counter = Counter(votes)\n",
        "    majority_vote, _ = counter.most_common(1)[0]\n",
        "    return majority_vote\n",
        "\n",
        "llm_majority_vote_dict = {}\n",
        "for data_point_id in gt[\"ID\"].dropna().astype(str).str.strip():\n",
        "    majority_vote = get_llm_majority_vote(data_point_id)\n",
        "    if majority_vote:\n",
        "        llm_majority_vote_dict[data_point_id] = majority_vote\n",
        "\n",
        "# Only consider items where both have a vote\n",
        "paired_ids = set(culled_majority_vote_dict.keys()) & set(llm_majority_vote_dict.keys())\n",
        "\n",
        "# Build contingency table\n",
        "# b = culled correct, llm incorrect\n",
        "# c = culled incorrect, llm correct\n",
        "b = c = 0\n",
        "for data_point_id in paired_ids:\n",
        "    gt_val = _norm_type(gt.loc[gt[\"ID\"].astype(str) == data_point_id, \"they_type\"].values[0]).replace(\"_they\", \"\")\n",
        "    culled_correct = int(_norm_type(culled_majority_vote_dict[data_point_id]) == gt_val)\n",
        "    llm_correct = int(_norm_type(llm_majority_vote_dict[data_point_id]) == gt_val)\n",
        "    if culled_correct and not llm_correct:\n",
        "        b += 1\n",
        "    elif not culled_correct and llm_correct:\n",
        "        c += 1\n",
        "\n",
        "table = [[0, b], [c, 0]]\n",
        "\n",
        "result = mcnemar(table, exact=True)\n",
        "p_value = result.pvalue"
      ],
      "id": "33e951e7",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Results by label\n",
        "\n",
        "### Singular vs Plural"
      ],
      "id": "ae21c0ff"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Collect accuracies for culled humans and best LLM for \"plural\" and \"singular\" labels\n",
        "\n",
        "# Compute by-label accuracy for culled human mean (not majority vote)\n",
        "all_culled_participant_dicts = []\n",
        "for block in culled_human_blocks:\n",
        "    all_culled_participant_dicts.extend(block)\n",
        "\n",
        "# Compute mean accuracy by label across all culled participants\n",
        "culled_by_label_accs = [compute_accuracy_by_label(participant, labels=(\"singular\", \"plural\")) for participant in all_culled_participant_dicts]\n",
        "\n",
        "# Average the accuracies for each label\n",
        "culled_by_label_acc = {}\n",
        "for label in (\"singular\", \"plural\"):\n",
        "    label_accs = [acc[label] for acc in culled_by_label_accs if not np.isnan(acc[label])]\n",
        "    culled_by_label_acc[label] = float(np.mean(label_accs)) if label_accs else float(\"nan\")\n",
        "\n",
        "# Compute by-label accuracy for best LLM majority vote\n",
        "llm_by_label_acc = compute_accuracy_by_label(llm_majority_vote_dict, labels=(\"singular\", \"plural\"))"
      ],
      "id": "753efdbc",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-singular-plural-comparison\n",
        "#| fig-cap: Accuracy difference between plural/singular _they_ and LLMs/humans\n",
        "\n",
        "# Prepare data for plotting by-label accuracies for culled humans and best LLM\n",
        "group_labels = [\"Culled Humans\", \"\", \"Best LLM\", \"\"]\n",
        "bar_values = [\n",
        "    culled_by_label_acc.get(\"plural\", float(\"nan\")),\n",
        "    culled_by_label_acc.get(\"singular\", float(\"nan\")),\n",
        "    llm_by_label_acc.get(\"plural\", float(\"nan\")),\n",
        "    llm_by_label_acc.get(\"singular\", float(\"nan\"))\n",
        "]\n",
        "# Blue for plural, red for singular\n",
        "bar_colors = [\n",
        "    \"#2C4C7E\", \"#B22222\",  # culled humans: plural (blue), singular (red)\n",
        "    \"#2C4C7E\", \"#B22222\"   # best LLM: plural (blue), singular (red)\n",
        "]\n",
        "bar_labels = [\"Plural\", \"Singular\", \"Plural\", \"Singular\"]\n",
        "\n",
        "# Increase space between the two pairs\n",
        "bar_positions = [0, 1, 3, 4]  # gap between 1 and 3\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(8, 6))\n",
        "bars = ax.bar(bar_positions, bar_values, color=bar_colors, edgecolor=\"black\", linewidth=1.5)\n",
        "\n",
        "# Format y-axis as percentages\n",
        "ax.set_ylim(0.33, 1.0)\n",
        "ax.yaxis.set_major_formatter(plt.FuncFormatter(lambda y, _: f\"{y*100:.0f}%\"))\n",
        "ax.set_ylabel(\"Accuracy\", fontsize=12)\n",
        "ax.grid(axis=\"y\", alpha=0.3)\n",
        "ax.set_axisbelow(True)\n",
        "\n",
        "# Set x-ticks to blank (we'll add group labels below)\n",
        "ax.set_xticks([])\n",
        "\n",
        "# Add group labels below the bars, spanning two bars each\n",
        "for idx, label in enumerate([\"Culled Humans\", \"Best LLM\"]):\n",
        "    xpos = bar_positions[idx * 2] + 0.5\n",
        "    ax.text(xpos, 0.31, label, ha=\"center\", va=\"top\", fontsize=14, fontweight=\"bold\")\n",
        "\n",
        "# Add legend for plural/singular\n",
        "from matplotlib.patches import Patch\n",
        "legend_elements = [\n",
        "    Patch(facecolor=\"#2C4C7E\", edgecolor=\"black\", label=\"Plural\"),\n",
        "    Patch(facecolor=\"#B22222\", edgecolor=\"black\", label=\"Singular\"),\n",
        "]\n",
        "ax.legend(handles=legend_elements, loc=\"upper left\", frameon=True)\n",
        "\n",
        "# Add bar labels (Plural/Singular) above each bar\n",
        "for i, bar in enumerate(bars):\n",
        "    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.01, bar_labels[i],\n",
        "            ha=\"center\", va=\"bottom\", fontsize=11)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "fig-singular-plural-comparison",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-confusion-matrix-llm\n",
        "#| fig-cap: Confusion matrix for the best LLM\n",
        "\n",
        "# Compute confusion matrices for best LLM and culled human mean (percentages)\n",
        "labels = [\"plural\", \"generic\", \"singular\"]\n",
        "\n",
        "# Prepare ground truth and predictions for paired items\n",
        "paired_ids = set()\n",
        "llm_preds = []\n",
        "human_preds = []\n",
        "gt_labels = []\n",
        "\n",
        "# For best LLM, use majority vote across runs\n",
        "for data_point_id in gt[\"ID\"].dropna().astype(str).str.strip():\n",
        "    # Only include if both LLM and at least one culled human have a prediction\n",
        "    llm_vote = get_llm_majority_vote(data_point_id)\n",
        "    human_votes = []\n",
        "    for participant in all_culled_participant_dicts:\n",
        "        if data_point_id in participant:\n",
        "            human_votes.append(_norm_type(participant[data_point_id]))\n",
        "    if llm_vote and human_votes:\n",
        "        paired_ids.add(data_point_id)\n",
        "        # LLM prediction\n",
        "        llm_preds.append(_norm_type(llm_vote))\n",
        "        # Human mean: use the most common label among culled humans for this item (not majority-vote dict, but mean)\n",
        "        counter = Counter(human_votes)\n",
        "        human_pred = counter.most_common(1)[0][0]\n",
        "        human_preds.append(human_pred)\n",
        "        # Ground truth\n",
        "        gt_label = _norm_type(gt.loc[gt[\"ID\"].astype(str) == data_point_id, \"they_type\"].values[0])\n",
        "        gt_labels.append(gt_label)\n",
        "\n",
        "# Add \"%\" to the labels\n",
        "labels_percent = [f\"{lbl} (%)\" for lbl in labels]\n",
        "\n",
        "# Confusion matrix for best LLM (percentages)\n",
        "cm_llm = confusion_matrix(gt_labels, llm_preds, labels=labels, normalize='true')\n",
        "disp_llm = ConfusionMatrixDisplay(confusion_matrix=cm_llm, display_labels=labels)\n",
        "fig, ax = plt.subplots(figsize=(5, 4))\n",
        "disp_llm.plot(ax=ax, cmap=\"Reds\", values_format=\".1%\")  # formats like 12.3%\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "fig-confusion-matrix-llm",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-confusion-matrix-human\n",
        "#| fig-cap: Confusion matrix for culled human mean\n",
        "\n",
        "cm_human = confusion_matrix(gt_labels, human_preds, labels=labels, normalize='true')\n",
        "disp_human = ConfusionMatrixDisplay(confusion_matrix=cm_human, display_labels=labels)\n",
        "fig, ax = plt.subplots(figsize=(5, 4))\n",
        "disp_human.plot(ax=ax, cmap=\"Blues\", values_format=\".1%\")\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "fig-confusion-matrix-human",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# TOST test for non-inferiority of the best LLM compared to culled human mean for \"singular\" label\n",
        "\n",
        "# Extract accuracies for \"singular\" label\n",
        "culled_singular_accuracies = [\n",
        "    acc[\"singular\"] for acc in culled_by_label_accs if not np.isnan(acc[\"singular\"])\n",
        "]\n",
        "\n",
        "llm_singular_accuracies = [\n",
        "    compute_accuracy_by_label(run, labels=(\"singular\",))[\"singular\"]\n",
        "    for run in commercial_llm_responses[top_3_llms[0][0]]\n",
        "    if not np.isnan(compute_accuracy_by_label(run, labels=(\"singular\",))[\"singular\"])\n",
        "]\n",
        "\n",
        "alpha = 0.05\n",
        "DELTA = 0.02\n",
        "\n",
        "p_equiv, (t_lower, p_lower, df_lower), (t_upper, p_upper, df_upper) = ttost_ind(\n",
        "    x1=llm_singular_accuracies,  # LLM first\n",
        "    x2=culled_singular_accuracies,\n",
        "    low=-DELTA, upp=DELTA,       # tests μ_LLM - μ_Human ∈ (-Δ, +Δ)\n",
        "    usevar=\"unequal\"             # Welch (recommended if variances differ)\n",
        ")\n",
        "\n",
        "non_inferior = (p_lower < alpha)\n",
        "\n",
        "Markdown(\n",
        "    f\"\"\"**TOST (independent samples, Welch)**\n",
        "\n",
        "- α = {alpha:.3f}, Δ = {DELTA:.3f}\n",
        "- t_lower={t_lower:.3f}, p_lower={p_lower:.4f} (NI decision uses this)\n",
        "- t_upper={t_upper:.3f}, p_upper={p_upper:.4f}\n",
        "\n",
        "**Decision**: Non-inferiority **{'established' if non_inferior else 'not established'}**.\n",
        "\"\"\"\n",
        ")"
      ],
      "id": "9aff560e",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Context-(in)dependence"
      ],
      "id": "01735b4d"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Assess performance for context-dependent vs context-independent items\n",
        "# for: best LLM, third-best LLM, and culled human mean\n",
        "\n",
        "# Get best and third-best LLM names from top_3_llms\n",
        "best_llm_name = top_3_llms[0][0]\n",
        "third_llm_name = top_3_llms[2][0]\n",
        "\n",
        "# Helper: compute mean accuracy for a group (list of participant dicts)\n",
        "def mean_accuracy_group(participant_dicts, context_dependent):\n",
        "    accs = [compute_accuracy(p, context_dependent=context_dependent) for p in participant_dicts]\n",
        "    accs = [a for a in accs if not np.isnan(a)]\n",
        "    return float(np.mean(accs)) if accs else float(\"nan\")\n",
        "\n",
        "# Prepare culled human participant dicts\n",
        "culled_human_participants = []\n",
        "for block in culled_human_blocks:\n",
        "    culled_human_participants.extend(block)\n",
        "\n",
        "# Compute accuracies\n",
        "results_context = []\n",
        "\n",
        "for context_flag, context_label in zip([1, 2], [\"Context-Dependent\", \"Context-Independent\"]):\n",
        "    # Best LLM\n",
        "    best_llm_accs = [compute_accuracy(run, context_dependent=context_flag) for run in commercial_llm_responses[best_llm_name]]\n",
        "    best_llm_acc = np.nanmean([a for a in best_llm_accs if not np.isnan(a)])\n",
        "    # Third-best LLM\n",
        "    third_llm_accs = [compute_accuracy(run, context_dependent=context_flag) for run in commercial_llm_responses[third_llm_name]]\n",
        "    third_llm_acc = np.nanmean([a for a in third_llm_accs if not np.isnan(a)])\n",
        "    # Culled human mean\n",
        "    culled_human_acc = mean_accuracy_group(culled_human_participants, context_dependent=context_flag)\n",
        "    # Store\n",
        "    results_context.append({\n",
        "        \"Group\": \"GPT-5 with URL Access\",\n",
        "        \"Context\": context_label,\n",
        "        \"Accuracy\": best_llm_acc\n",
        "    })\n",
        "    results_context.append({\n",
        "        \"Group\": \"GPT-5 Context-Agnostic\",\n",
        "        \"Context\": context_label,\n",
        "        \"Accuracy\": third_llm_acc\n",
        "    })\n",
        "    results_context.append({\n",
        "        \"Group\": \"Culled Human Mean\",\n",
        "        \"Context\": context_label,\n",
        "        \"Accuracy\": culled_human_acc\n",
        "    })\n",
        "\n",
        "# Display as table\n",
        "results_context_df = pd.DataFrame(results_context)\n",
        "results_context_df[\"Accuracy\"] = results_context_df[\"Accuracy\"].apply(lambda x: f\"{x*100:.1f}%\" if not np.isnan(x) else \"n/a\")"
      ],
      "id": "8bf7f91b",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: tbl-context-accuracy\n",
