    "\"Significance test\"\n",
    "\n",
    "ALPHA = 0.05\n",
    "\n",
    "# McNemar's test to compare best LLM vs. culled humans\n",
    "\n",
    "from statsmodels.stats.contingency_tables import mcnemar\n",
    "\n",
    "# For McNemar's test, we need paired binary outcomes for the same items.\n",
    "# We'll use the majority vote of culled humans vs. the best LLM (majority vote across runs).\n",
    "\n",
    "# Build majority vote for best LLM\n",
    "def get_llm_majority_vote(data_point_id):\n",
    "    votes = []\n",
    "    for run in commercial_llm_responses[top_3_llms[0][0]]:\n",
    "        if data_point_id in run:\n",
    "            votes.append(_norm_type(run[data_point_id]))\n",
    "    if not votes:\n",
    "        return None\n",
    "    counter = Counter(votes)\n",
    "    majority_vote, _ = counter.most_common(1)[0]\n",
    "    return majority_vote\n",
    "\n",
    "llm_majority_vote_dict = {}\n",
    "for data_point_id in gt[\"ID\"].dropna().astype(str).str.strip():\n",
    "    majority_vote = get_llm_majority_vote(data_point_id)\n",
    "    if majority_vote:\n",
    "        llm_majority_vote_dict[data_point_id] = majority_vote\n",
    "\n",
    "# Only consider items where both have a vote\n",
    "paired_ids = set(culled_majority_vote_dict.keys()) & set(llm_majority_vote_dict.keys())\n",
    "\n",
    "# Build contingency table\n",
    "# b = culled correct, llm incorrect\n",
    "# c = culled incorrect, llm correct\n",
    "b = c = 0\n",
    "for data_point_id in paired_ids:\n",
    "    gt_val = _norm_type(gt.loc[gt[\"ID\"].astype(str) == data_point_id, \"they_type\"].values[0]).replace(\"_they\", \"\")\n",
    "    culled_correct = int(_norm_type(culled_majority_vote_dict[data_point_id]) == gt_val)\n",
    "    llm_correct = int(_norm_type(llm_majority_vote_dict[data_point_id]) == gt_val)\n",
    "    if culled_correct and not llm_correct:\n",
    "        b += 1\n",
    "    elif not culled_correct and llm_correct:\n",
    "        c += 1\n",
    "\n",
    "table = [[0, b], [c, 0]]\n",
    "\n",
    "result = mcnemar(table, exact=True)\n",
    "p_value = result.pvalue"
   ]
