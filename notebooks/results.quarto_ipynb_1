    "# Assess performance for context-dependent vs context-independent items\n",
    "# for: best LLM, third-best LLM, and culled human mean\n",
    "\n",
    "# Get best and third-best LLM names from top_3_llms\n",
    "best_llm_name = top_3_llms[0][0]\n",
    "third_llm_name = top_3_llms[2][0]\n",
    "\n",
    "# Helper: compute mean accuracy for a group (list of participant dicts)\n",
    "def mean_accuracy_group(participant_dicts, context_dependent):\n",
    "    accs = [compute_accuracy(p, context_dependent=context_dependent) for p in participant_dicts]\n",
    "    accs = [a for a in accs if not np.isnan(a)]\n",
    "    return float(np.mean(accs)) if accs else float(\"nan\")\n",
    "\n",
    "# Prepare culled human participant dicts\n",
    "culled_human_participants = []\n",
    "for block in culled_human_blocks:\n",
    "    culled_human_participants.extend(block)\n",
    "\n",
    "# Compute accuracies\n",
    "results_context = []\n",
    "\n",
    "for context_flag, context_label in zip([1, 2], [\"Context-Dependent\", \"Context-Independent\"]):\n",
    "    # Best LLM\n",
    "    best_llm_accs = [compute_accuracy(run, context_dependent=context_flag) for run in commercial_llm_responses[best_llm_name]]\n",
    "    best_llm_acc = np.nanmean([a for a in best_llm_accs if not np.isnan(a)])\n",
    "    # Third-best LLM\n",
    "    third_llm_accs = [compute_accuracy(run, context_dependent=context_flag) for run in commercial_llm_responses[third_llm_name]]\n",
    "    third_llm_acc = np.nanmean([a for a in third_llm_accs if not np.isnan(a)])\n",
    "    # Culled human mean\n",
    "    culled_human_acc = mean_accuracy_group(culled_human_participants, context_dependent=context_flag)\n",
    "    # Store\n",
    "    results_context.append({\n",
    "        \"Group\": \"GPT-5 with URL Access\",\n",
    "        \"Context\": context_label,\n",
    "        \"Accuracy\": best_llm_acc\n",
    "    })\n",
    "    results_context.append({\n",
    "        \"Group\": \"GPT-5 Context-Agnostic\",\n",
    "        \"Context\": context_label,\n",
    "        \"Accuracy\": third_llm_acc\n",
    "    })\n",
    "    results_context.append({\n",
    "        \"Group\": \"Culled Human Mean\",\n",
    "        \"Context\": context_label,\n",
    "        \"Accuracy\": culled_human_acc\n",
    "    })\n",
